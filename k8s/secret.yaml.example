# Example secret manifest for RIG credentials.
# Copy this file to secret.yaml and fill in real values before applying.
#
# The IRI demo adapter uses api_key="12345" — this example reflects that.
# In production, replace with real facility tokens.
#
# Secret keys:
#   RIG_POLICY_ENGINE_URL   — external policy engine URL (optional)
#
# Per-user vaulted credentials use separate secrets with the naming convention:
#   rig-creds-{user}-{project}-{facility}
# See rbac.yaml for the required RBAC to read those secrets.
---
apiVersion: v1
kind: Secret
metadata:
  name: rig-secrets
  namespace: rig
type: Opaque
stringData:
  RIG_POLICY_ENGINE_URL: ""
---
# Example: vaulted credential for user "demo", project "iri-demo", facility "nersc"
# This uses the IRI demo adapter api_key convention.
apiVersion: v1
kind: Secret
metadata:
  name: rig-creds-demo-iri-demo-nersc
  namespace: rig
type: Opaque
stringData:
  token: "12345"
